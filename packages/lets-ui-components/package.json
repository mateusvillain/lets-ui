{
  "name": "@lets-ui/components",
  "version": "1.5.1",
  "description": "Let's UI Web Components package",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/mateusvillain/lets-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateusvillain/lets-ui.git",
    "directory": "packages/lets-ui-components"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "design-system",
    "ui-components",
    "lets-ui"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./alert": "./dist/components/alert.js",
    "./breadcrumb": "./dist/components/breadcrumb.js",
    "./breadcrumb-item": "./dist/components/breadcrumb-item.js",
    "./button": "./dist/components/button.js",
    "./card": "./dist/components/card.js",
    "./checkbox": "./dist/components/checkbox.js",
    "./drawer": "./dist/components/drawer.js",
    "./dropdown-menu": "./dist/components/dropdown-menu.js",
    "./divider": "./dist/components/divider.js",
    "./icon-button": "./dist/components/icon-button.js",
    "./input": "./dist/components/input.js",
    "./link": "./dist/components/link.js",
    "./modal": "./dist/components/modal.js",
    "./radio": "./dist/components/radio.js",
    "./select": "./dist/components/select.js",
    "./shortcut": "./dist/components/shortcut.js",
    "./switch": "./dist/components/switch.js",
    "./tabs": "./dist/components/tabs.js",
    "./tag": "./dist/components/tag.js",
    "./tooltip": "./dist/components/tooltip.js",
    "./textarea": "./dist/components/textarea.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@lets-ui/styles": "workspace:*",
    "@lets-ui/tokens": "workspace:*",
    "@types/node": "^22.0.0",
    "sass": "^1.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
