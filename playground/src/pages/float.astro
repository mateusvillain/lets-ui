---
import '@lets-ui/tokens';
import '@lets-ui/styles';
---

<html lang="pt-BR" data-theme="light" data-brand="lets-ui">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Float — Let's UI Playground</title>
    <script>
      import '@lets-ui/components';
    </script>
  </head>
  <body>
    <header class="pg-header">
      <a href="/" class="pg-header__back">← Playground</a>
      <span class="pg-header__title">lui-float</span>
      <span class="pg-header__tag">Posicionamento absoluto</span>
    </header>

    <main class="pg-main">

      <!-- ── Intro ──────────────────────────────────────────────── -->
      <section class="pg-section">
        <div class="pg-callout">
          <strong>Como funciona:</strong> <code>lui-float</code> cria um
          contexto de posicionamento relativo ao redor do conteúdo principal.
          O elemento no slot <code>float</code> é posicionado absolutamente
          no ponto indicado por <code>placement</code>. Use
          <code>offset-x</code> e <code>offset-y</code> para ajuste fino.
        </div>
      </section>

      <!-- ── Todos os placements ────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Todos os placements</h2>
        <p class="pg-section__desc">
          Nove posições disponíveis: combinações de <em>top / middle / bottom</em>
          com <em>start / center / end</em>.
        </p>

        <div class="placement-grid">
          {[
            'top-start', 'top-center', 'top-end',
            'middle-start', 'middle-center', 'middle-end',
            'bottom-start', 'bottom-center', 'bottom-end',
          ].map((p) => (
            <div class="placement-item">
              <lui-float placement={p}>
                <div class="demo-box"></div>
                <span slot="float" class="demo-badge">3</span>
              </lui-float>
              <span class="placement-label">{p}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Avatar com badge de notificação ───────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Avatar com badge</h2>
        <p class="pg-section__desc">
          Caso de uso clássico: badge de contagem ou indicador de status
          sobreposto a um avatar.
        </p>

        <div class="demo-row">
          <div class="demo-item">
            <lui-float placement="bottom-end">
              <div class="avatar">MV</div>
              <span slot="float" class="status-dot status-dot--online"></span>
            </lui-float>
            <span class="demo-item__label">Online (bottom-end)</span>
          </div>

          <div class="demo-item">
            <lui-float placement="top-end">
              <div class="avatar">JD</div>
              <span slot="float" class="count-badge">5</span>
            </lui-float>
            <span class="demo-item__label">Notificações (top-end)</span>
          </div>

          <div class="demo-item">
            <lui-float placement="bottom-end">
              <div class="avatar avatar--lg">AB</div>
              <span slot="float" class="count-badge count-badge--lg">99+</span>
            </lui-float>
            <span class="demo-item__label">Contagem alta (bottom-end)</span>
          </div>

          <div class="demo-item">
            <lui-float placement="bottom-start">
              <div class="avatar">KL</div>
              <span slot="float" class="status-dot status-dot--busy"></span>
            </lui-float>
            <span class="demo-item__label">Ocupado (bottom-start)</span>
          </div>
        </div>
      </section>

      <!-- ── Offset ─────────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Com offset</h2>
        <p class="pg-section__desc">
          <code>offset-x</code> e <code>offset-y</code> ajustam o
          posicionamento em pixels além do ponto de ancoragem padrão.
        </p>

        <div class="demo-row">
          <div class="demo-item">
            <lui-float placement="top-end" offset-x="-4" offset-y="4">
              <div class="demo-box"></div>
              <span slot="float" class="demo-badge">!</span>
            </lui-float>
            <span class="demo-item__label">offset-x="-4" offset-y="4"</span>
          </div>

          <div class="demo-item">
            <lui-float placement="bottom-end" offset-x="4" offset-y="-4">
              <div class="demo-box"></div>
              <span slot="float" class="demo-badge">!</span>
            </lui-float>
            <span class="demo-item__label">offset-x="4" offset-y="-4"</span>
          </div>

          <div class="demo-item">
            <lui-float placement="top-end">
              <div class="demo-box"></div>
              <span slot="float" class="demo-badge">!</span>
            </lui-float>
            <span class="demo-item__label">Sem offset (padrão)</span>
          </div>
        </div>
      </section>

      <!-- ── Dentro de um card ───────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Aplicado a cards</h2>
        <p class="pg-section__desc">
          <code>lui-float</code> funciona com qualquer elemento como âncora.
        </p>

        <div class="demo-row">
          <lui-float placement="top-end">
            <lui-card style="width: 160px; padding: 16px; display: block;">
              <p style="margin: 0; font-size: 14px; font-weight: 600;">Produto A</p>
              <p style="margin: 4px 0 0; font-size: 13px; opacity: 0.6;">R$ 49,90</p>
            </lui-card>
            <span slot="float" class="tag-badge">Novo</span>
          </lui-float>

          <lui-float placement="top-start">
            <lui-card style="width: 160px; padding: 16px; display: block;">
              <p style="margin: 0; font-size: 14px; font-weight: 600;">Produto B</p>
              <p style="margin: 4px 0 0; font-size: 13px; opacity: 0.6;">R$ 89,90</p>
            </lui-card>
            <span slot="float" class="tag-badge tag-badge--sale">-20%</span>
          </lui-float>
        </div>
      </section>

    </main>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--lui-color-neutral-background-surface, #f5f5f5);
    color: var(--lui-color-neutral-text-body, #1a1a1a);
  }

  /* ── Header ───────────────────────────── */
  .pg-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: var(--lui-color-neutral-background-surface-primary, #fff);
    border-bottom: 1px solid var(--lui-color-neutral-border-subtle, #e5e7eb);
    font-size: 14px;
  }
  .pg-header__back {
    color: inherit;
    text-decoration: none;
    opacity: 0.5;
  }
  .pg-header__back:hover { opacity: 1; }
  .pg-header__title {
    font-weight: 600;
    font-family: monospace;
  }
  .pg-header__tag {
    font-size: 11px;
    background: #fef3c7;
    color: #92400e;
    padding: 2px 8px;
    border-radius: 999px;
  }

  /* ── Layout ───────────────────────────── */
  .pg-main {
    display: flex;
    flex-direction: column;
    gap: 56px;
    padding: 40px 24px 80px;
    max-width: 900px;
    margin: 0 auto;
  }

  .pg-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pg-section__title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--lui-color-neutral-text-caption, #6b7280);
  }

  .pg-section__desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--lui-color-neutral-text-caption, #6b7280);
    max-width: 620px;
  }

  .pg-callout {
    font-size: 13px;
    line-height: 1.6;
    padding: 12px 16px;
    background: #fefce8;
    border-left: 3px solid #eab308;
    border-radius: 4px;
  }
  .pg-callout code {
    font-family: monospace;
    font-size: 12px;
    background: rgba(0, 0, 0, 0.06);
    padding: 1px 4px;
    border-radius: 3px;
  }

  /* ── Placement grid ───────────────────── */
  .placement-grid {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 48px 64px;
    justify-content: start;
    padding: 24px;
    background: #fff;
    border: 1px solid var(--lui-color-neutral-border-subtle, #e5e7eb);
    border-radius: 12px;
  }

  .placement-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .placement-label {
    font-family: monospace;
    font-size: 11px;
    color: var(--lui-color-neutral-text-caption, #6b7280);
  }

  /* ── Demo box (anchor) ────────────────── */
  .demo-box {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    background: #e5e7eb;
  }

  /* ── Demo badge (float element) ───────── */
  .demo-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #ef4444;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    border: 2px solid #fff;
  }

  /* ── Demo row ─────────────────────────── */
  .demo-row {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
    align-items: flex-end;
    padding: 24px;
    background: #fff;
    border: 1px solid var(--lui-color-neutral-border-subtle, #e5e7eb);
    border-radius: 12px;
  }

  .demo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .demo-item__label {
    font-family: monospace;
    font-size: 11px;
    color: var(--lui-color-neutral-text-caption, #6b7280);
  }

  /* ── Avatar ───────────────────────────── */
  .avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar--lg {
    width: 64px;
    height: 64px;
    font-size: 18px;
  }

  /* ── Status dot ───────────────────────── */
  .status-dot {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #fff;
  }

  .status-dot--online { background: #22c55e; }
  .status-dot--busy   { background: #ef4444; }

  /* ── Count badge ──────────────────────── */
  .count-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    border: 2px solid #fff;
  }

  .count-badge--lg {
    min-width: 22px;
    height: 22px;
    font-size: 11px;
  }

  /* ── Tag badge ────────────────────────── */
  .tag-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 999px;
    background: #3b82f6;
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    border: 2px solid #fff;
    white-space: nowrap;
  }

  .tag-badge--sale {
    background: #ef4444;
  }
</style>
