---
import '@lets-ui/tokens';
import '@lets-ui/styles';
---

<html lang="pt-BR" data-theme="light" data-brand="lets-ui">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scroll Area — Let's UI Playground</title>
    <script>
      import '@lets-ui/components';
    </script>
  </head>
  <body>
    <header class="pg-header">
      <a href="/" class="pg-header__back">← Playground</a>
      <span class="pg-header__title">lui-scroll-area</span>
      <span class="pg-header__tag">Área rolável</span>
    </header>

    <main class="pg-main">

      <!-- ── Intro ──────────────────────────────────────────────── -->
      <section class="pg-section">
        <div class="pg-callout">
          <strong>Como funciona:</strong> <code>lui-scroll-area</code> cria
          uma região rolável acessível via teclado. Controla overflow,
          indicadores visuais, scroll snap e emite eventos como
          <code>scroll</code>, <code>scroll-end</code> e <code>reach-bottom</code>.
        </div>
      </section>

      <!-- ── Vertical (padrão) ──────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Vertical (padrão)</h2>
        <p class="pg-section__desc">
          Rolagem vertical com altura fixa e conteúdo que ultrapassa o limite.
        </p>
        <div class="demo-box">
          <lui-scroll-area height="200">
            <div class="long-content">
              {Array.from({ length: 20 }, (_, i) => (
                <p class="content-item">Item {i + 1} — conteúdo de exemplo</p>
              ))}
            </div>
          </lui-scroll-area>
        </div>
      </section>

      <!-- ── Horizontal ─────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Horizontal</h2>
        <p class="pg-section__desc">
          Rolagem horizontal para galerias e listas de cards.
        </p>
        <div class="demo-box">
          <lui-scroll-area orientation="horizontal">
            <div class="horizontal-content">
              {Array.from({ length: 12 }, (_, i) => (
                <div class="card-thumb">Card {i + 1}</div>
              ))}
            </div>
          </lui-scroll-area>
        </div>
      </section>

      <!-- ── Both ───────────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Both (vertical + horizontal)</h2>
        <p class="pg-section__desc">
          Rolagem em ambas as direções, útil para tabelas e mapas.
        </p>
        <div class="demo-box">
          <lui-scroll-area orientation="both" height="180" max-width="100%">
            <div class="grid-content">
              {Array.from({ length: 8 }, (_, row) => (
                <div class="grid-row">
                  {Array.from({ length: 10 }, (_, col) => (
                    <div class="grid-cell">{row + 1}×{col + 1}</div>
                  ))}
                </div>
              ))}
            </div>
          </lui-scroll-area>
        </div>
      </section>

      <!-- ── Scrollbar visibility ───────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">scrollbar-visibility</h2>
        <p class="pg-section__desc">
          Controla quando a scrollbar aparece.
          <code>hover</code> esconde até o mouse entrar na área;
          <code>hidden</code> nunca mostra a scrollbar (mas o conteúdo ainda rola).
        </p>
        <div class="variant-row">
          <div class="variant-item">
            <span class="variant-label">auto</span>
            <div class="demo-box">
              <lui-scroll-area height="120" scrollbar-visibility="auto">
                <div class="long-content">
                  {Array.from({ length: 10 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
          <div class="variant-item">
            <span class="variant-label">always</span>
            <div class="demo-box">
              <lui-scroll-area height="120" scrollbar-visibility="always">
                <div class="long-content">
                  {Array.from({ length: 10 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
          <div class="variant-item">
            <span class="variant-label">hover</span>
            <div class="demo-box">
              <lui-scroll-area height="120" scrollbar-visibility="hover">
                <div class="long-content">
                  {Array.from({ length: 10 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
          <div class="variant-item">
            <span class="variant-label">hidden</span>
            <div class="demo-box">
              <lui-scroll-area height="120" scrollbar-visibility="hidden">
                <div class="long-content">
                  {Array.from({ length: 10 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Fade ───────────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">fade</h2>
        <p class="pg-section__desc">
          Gradiente nas bordas para indicar conteúdo oculto. Atualiza
          automaticamente durante a rolagem. Use <code>fade</code> para todas
          as direções ou <code>fade="top bottom"</code> para direções específicas.
          Personalize a cor com <code>--lui-scroll-area-fade-color</code>.
        </p>
        <div class="variant-row">
          <div class="variant-item">
            <span class="variant-label">fade (boolean)</span>
            <div class="demo-box">
              <lui-scroll-area height="160" fade>
                <div class="long-content">
                  {Array.from({ length: 15 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
          <div class="variant-item">
            <span class="variant-label">fade="bottom"</span>
            <div class="demo-box">
              <lui-scroll-area height="160" fade="bottom">
                <div class="long-content">
                  {Array.from({ length: 15 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Scroll Shadow ──────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">scroll-shadow</h2>
        <p class="pg-section__desc">
          Sombra sutil nas bordas — alternativa ao fade que funciona
          independente da cor do fundo.
        </p>
        <div class="demo-box demo-box--dark">
          <lui-scroll-area height="200" scroll-shadow>
            <div class="long-content">
              {Array.from({ length: 20 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
            </div>
          </lui-scroll-area>
        </div>
      </section>

      <!-- ── Scroll Snap ────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">snap</h2>
        <p class="pg-section__desc">
          CSS Scroll Snap nativo. Combine com <code>snap-align</code>
          para controlar o alinhamento dos itens.
        </p>
        <div class="demo-box">
          <lui-scroll-area orientation="horizontal" snap snap-align="start">
            <div class="snap-content">
              {Array.from({ length: 6 }, (_, i) => (
                <div class="snap-slide" style={`background: hsl(${i * 50}, 60%, 80%)`}>
                  Slide {i + 1}
                </div>
              ))}
            </div>
          </lui-scroll-area>
        </div>
      </section>

      <!-- ── Overscroll ──────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">overscroll</h2>
        <p class="pg-section__desc">
          <code>contain</code> impede que o scroll se propague para a página
          ao atingir o limite.
        </p>
        <div class="variant-row">
          <div class="variant-item">
            <span class="variant-label">overscroll="auto"</span>
            <div class="demo-box">
              <lui-scroll-area height="120" overscroll="auto">
                <div class="long-content">
                  {Array.from({ length: 10 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
          <div class="variant-item">
            <span class="variant-label">overscroll="contain"</span>
            <div class="demo-box">
              <lui-scroll-area height="120" overscroll="contain">
                <div class="long-content">
                  {Array.from({ length: 10 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
                </div>
              </lui-scroll-area>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Disabled ───────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">disabled</h2>
        <p class="pg-section__desc">
          Bloqueia toda interação de rolagem (mouse, touch, teclado).
        </p>
        <div class="demo-box">
          <lui-scroll-area height="150" disabled>
            <div class="long-content">
              {Array.from({ length: 12 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
            </div>
          </lui-scroll-area>
        </div>
      </section>

      <!-- ── Eventos ────────────────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">Eventos</h2>
        <p class="pg-section__desc">
          Role para ver os eventos emitidos: <code>scroll</code>,
          <code>scroll-start</code>, <code>scroll-end</code>,
          <code>reach-top</code> e <code>reach-bottom</code>.
        </p>
        <div class="events-demo">
          <lui-scroll-area height="200" fade id="events-area">
            <div class="long-content">
              {Array.from({ length: 20 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
            </div>
          </lui-scroll-area>
          <div class="event-log" id="event-log">
            <span class="event-log__empty">Nenhum evento ainda — role a área acima.</span>
          </div>
        </div>
        <script>
          const area = document.getElementById('events-area');
          const log = document.getElementById('event-log');
          const MAX_ENTRIES = 8;

          function addEntry(name, detail) {
            const empty = log.querySelector('.event-log__empty');
            if (empty) empty.remove();

            const entry = document.createElement('div');
            entry.className = 'event-entry';
            entry.innerHTML = `<strong>${name}</strong>${detail ? ` <span class="event-detail">${JSON.stringify(detail).slice(0, 60)}</span>` : ''}`;
            log.insertBefore(entry, log.firstChild);

            const entries = log.querySelectorAll('.event-entry');
            if (entries.length > MAX_ENTRIES) entries[entries.length - 1].remove();
          }

          area.addEventListener('scroll-start', () => addEntry('scroll-start'));
          area.addEventListener('scroll-end', () => addEntry('scroll-end'));
          area.addEventListener('reach-top', () => addEntry('reach-top'));
          area.addEventListener('reach-bottom', () => addEntry('reach-bottom'));
          area.addEventListener('scroll', (e) => {
            addEntry('scroll', { top: Math.round(e.detail.scrollTop), left: e.detail.scrollLeft });
          });
        </script>
      </section>

      <!-- ── max-height dinâmico ────────────────────────────────── -->
      <section class="pg-section">
        <h2 class="pg-section__title">max-height</h2>
        <p class="pg-section__desc">
          Expande com o conteúdo até atingir o limite definido.
        </p>
        <div class="demo-box">
          <lui-scroll-area max-height="200" fade>
            <div class="long-content">
              {Array.from({ length: 15 }, (_, i) => <p class="content-item">Item {i + 1}</p>)}
            </div>
          </lui-scroll-area>
        </div>
      </section>

    </main>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--lui-color-neutral-background-surface, #f5f5f5);
    color: var(--lui-color-neutral-text-body, #1a1a1a);
  }

  /* ── Header ───────────────────────────── */
  .pg-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: var(--lui-color-neutral-background-surface-primary, #fff);
    border-bottom: 1px solid var(--lui-color-neutral-border-subtle, #e5e7eb);
    font-size: 14px;
  }
  .pg-header__back { color: inherit; text-decoration: none; opacity: 0.5; }
  .pg-header__back:hover { opacity: 1; }
  .pg-header__title { font-weight: 600; font-family: monospace; }
  .pg-header__tag {
    font-size: 11px;
    background: #fef3c7;
    color: #92400e;
    padding: 2px 8px;
    border-radius: 999px;
  }

  /* ── Layout ───────────────────────────── */
  .pg-main {
    display: flex;
    flex-direction: column;
    gap: 56px;
    padding: 40px 24px 80px;
    max-width: 900px;
    margin: 0 auto;
  }
  .pg-section { display: flex; flex-direction: column; gap: 16px; }
  .pg-section__title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--lui-color-neutral-text-caption, #6b7280);
  }
  .pg-section__desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--lui-color-neutral-text-caption, #6b7280);
    max-width: 620px;
  }
  .pg-section__desc code,
  .pg-callout code {
    font-family: monospace;
    font-size: 12px;
    background: rgba(0,0,0,0.06);
    padding: 1px 4px;
    border-radius: 3px;
  }
  .pg-callout {
    font-size: 13px;
    line-height: 1.6;
    padding: 12px 16px;
    background: #fefce8;
    border-left: 3px solid #eab308;
    border-radius: 4px;
  }

  /* ── Demo shell ───────────────────────── */
  .demo-box {
    background: var(--lui-color-neutral-background-surface-primary, #fff);
    border: 1px solid var(--lui-color-neutral-border-subtle, #e5e7eb);
    border-radius: 12px;
    padding: 16px;
  }
  .demo-box--dark {
    background: #1e293b;
  }

  /* ── Content helpers ──────────────────── */
  .long-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .content-item {
    margin: 0;
    padding: 8px 12px;
    font-size: 13px;
    border-bottom: 1px solid var(--lui-color-neutral-border-subtle, #f3f4f6);
  }
  .content-item:last-child { border-bottom: none; }

  .horizontal-content {
    display: flex;
    gap: 12px;
    padding: 4px 0;
  }
  .card-thumb {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 8px;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    color: #6b7280;
  }

  .grid-content { display: flex; flex-direction: column; gap: 2px; min-width: 600px; }
  .grid-row { display: flex; gap: 2px; }
  .grid-cell {
    flex-shrink: 0;
    width: 56px;
    height: 36px;
    background: #f3f4f6;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: #6b7280;
    font-variant-numeric: tabular-nums;
  }

  /* ── Snap ─────────────────────────────── */
  .snap-content {
    display: flex;
    gap: 0;
  }
  .snap-slide {
    flex-shrink: 0;
    width: 100%;
    min-width: min(300px, 80vw);
    height: 120px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: rgba(0,0,0,0.5);
    margin-right: 12px;
  }
  .snap-slide:last-child { margin-right: 0; }

  /* ── Variants row ─────────────────────── */
  .variant-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .variant-item {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .variant-label {
    font-family: monospace;
    font-size: 11px;
    color: var(--lui-color-neutral-text-caption, #6b7280);
  }

  /* ── Events demo ──────────────────────── */
  .events-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) { .events-demo { grid-template-columns: 1fr; } }
  .event-log {
    background: #0f172a;
    border-radius: 8px;
    padding: 12px;
    font-family: monospace;
    font-size: 12px;
    color: #94a3b8;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 200px;
  }
  .event-log__empty { color: #475569; font-style: italic; }
  .event-entry { color: #e2e8f0; line-height: 1.5; }
  .event-entry strong { color: #38bdf8; }
  .event-detail { color: #64748b; }
</style>
